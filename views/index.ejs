<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BLOG</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include("header.ejs") %>
   <main class="container">

    <!-- HERO SECTION -->
    <section class="hero">
        <p class="tag">A PERSONAL BLOG</p>
        <h1>Your thoughts,<br><span>beautifully written.</span></h1>
        <p class="subtitle">
            Write, edit, and revisit your stories — all in one place.
        </p>
    </section>

    <!-- POSTS -->
    <section class="posts">
        <% posts.forEach(post => { %>
            <div class="card">
                <p class="date"><%= post.date %></p>
                <h2><%= post.title %></h2>
                <p class="content">
                    <%= post.content.substring(0, 100) %>...
                </p>
                <div class="actions">
  <% if (isLoggedIn) { %>
    <a href="/edit/<%= post._id %>" class="btn edit">✏ Edit</a>
    <a href="/delete/<%= post._id %>" class="btn delete">🗑 Delete</a>
  <% } %>
</div>
            </div>
        <% }) %>
    </section>
    

</main>
    
</body>
</html>